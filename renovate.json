{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": false,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Docker image versions in snapshot generator tests",
      "fileMatch": ["^backend/src/test/.*\\.java$"],
      "matchStrings": [
        "DockerImageName\\.parse\\(\"(?<depName>[^:\"]+):(?<currentValue>[^\"]+)\"\\)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchUpdateTypes": ["patch"]
    }
  ]
}
